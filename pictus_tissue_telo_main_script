pictus_tissue <- mutate(pictus_tissue, log_rtl = log(rtl))

```

```{r}

tissue_summary <- pictus_tissue %>%
  group_by(Tissue) %>%
  summarise(
    n = n(),
    mean_rtl = mean(rtl_new, na.rm = TRUE),
    sd_rtl = sd(rtl_new, na.rm = TRUE),
    se_rtl = sd(rtl_new, na.rm = TRUE) / sqrt(n())
  )

tissue_summary
```



```{r}


tissue_model <- lmer(log(rtl_new) ~ Tissue * Room * Population  + (1 | ID) + (1|Tisrun),
  data = pictus_tissue)
r.squaredGLMM(tissue_model)
icc(tissue_model)
summary(tissue_model)
anova(tissue_model)
```



```{r}
reduced_model <- lmer(log(rtl_new) ~ Tissue * Room * Population + (1|ID),
