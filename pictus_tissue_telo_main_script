```{r}
library(ggplot2)

pd  <- position_dodge(width = 0.6) 
pjd <- position_jitterdodge(dodge.width = 0.6, jitter.width = 0.05)

tissue_plot <- ggplot(pictus_tissue,
       aes(x = Tissue,
           y = log(rtl_new),
           fill= Tissue,
           shape=Tissue)) +     

  # jittered points
  geom_point(position = pjd,
             size      = 1.5,
             alpha     = 0.2,
             colour    = "black") +

  # mean ± SE
  stat_summary(
    aes(fill = Tissue),   # map fill to treatment
    fun.data = mean_se,
    geom = "errorbar",
    width = 0,
    size=2,
    position = pd
  ) +
  stat_summary(
    aes(fill = Tissue),   # mean point with treatment color
    fun = mean,
    geom = "point",
    shape = 21,              # filled circle
